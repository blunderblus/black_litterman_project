# BL 프로젝트 환경설정 템플릿 — 복사해서 `.env`로 사용 (시크릿 값은 절대 커밋 금지)
# 모든 키는 BL_ 프리픽스를 사용한다(설계: 01-system-architecture §8.1).
# 로딩: bl.common.config:get_settings()

# ---- 경로/실행 ----
BL_ENV=dev                       # dev | operational | demo
BL_DATA_ROOT=data                # 데이터 루트(로컬 경로 또는 객체스토리지 URI)
# 아래 두 개는 미지정 시 BL_DATA_ROOT 기준으로 자동 파생된다.
# BL_ARTIFACTS_DIR=data/artifacts
# BL_DUCKDB_PATH=data/raw_collection.duckdb

# ---- 연산 백엔드 ----
BL_COMPUTE_BACKEND=auto          # auto | cpu | gpu  (auto: GPU 있으면 CuPy, 없으면 NumPy)
BL_SEED=42                       # 재현성 시드

# ---- 수집 동작 플래그 ----
BL_FULL_REBUILD=false            # 재무 풀리빌드
BL_ONLY_EMPTY=true               # 증분 적재(빈 키만)

# ---- 외부 API 시크릿 (값 비워서 커밋. 실제 값은 .env/시크릿매니저에만) ----
BL_DART_API_KEY=
BL_ECOS_API_KEY=
BL_NAVER_CLIENT_ID=
BL_NAVER_CLIENT_SECRET=
BL_GEMINI_API_KEY=
# (BigKinds는 폐쇄적 API라 사용하지 않음 — 뉴스는 Naver만)
